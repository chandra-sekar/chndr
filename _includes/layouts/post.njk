---
layout: layouts/base.njk
---
<section class="h-entry">
	<h2 class="p-name">{{ title }}</h2>
	<time class="dt-published" datetime="{{ date | htmlDateString }}">{{ date | readableDate }}</time>
		{{ content | safe }}
	{%- if syndication -%}
		<a href="{{ syndication }}" class="u-syndication" rel="syndication">Mastodon</a>
	{%- endif -%}
	{%- set pageUrl = metadata.url.slice(0, -1) + page.url -%}
	{%- set mentions = webmentions[pageUrl] -%}
	{%- if mentions -%}
		{%- if mentions.likes.length or mentions.reposts.length -%}
			<p class="webmentions-counts">{{ mentions.likes.length }} like{{ 's' if mentions.likes.length != 1 }} · {{ mentions.reposts.length }} boost{{ 's' if mentions.reposts.length != 1 }}</p>
		{%- endif -%}
		{%- for reply in mentions.replies -%}
			<p class="webmention-reply"><a href="{{ reply.url }}">{{ reply.author.name if reply.author else reply.url }}</a>: {{ reply.content.text if reply.content else '' }}</p>
		{%- endfor -%}
	{%- endif -%}
</section>