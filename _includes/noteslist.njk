<div class="noteslist h-feed">
{% for note in noteslist %}
  <section class="h-entry noteslist-item{% if note.url == url %} noteslist-item-active{% endif %}">
   <div>
    {%- if note.data["bookmark-of"] -%}
      <div><a href="{{ note.data['bookmark-of'] }}" class="u-bookmark-of">→ {{ note.data.name if note.data.name else note.data["bookmark-of"] }}</a></div>
    {%- endif -%}
    {{ note.templateContent | safe }}
    {%- if note.data.photo -%}
      {% for photo in note.data.photo %}
        <img src="{{ photo.url | url }}">
      {% endfor %}
    {%- endif -%}
    {%- if note.data.syndication -%}
      <a href="{{ note.data.syndication }}" class="u-syndication" rel="syndication">Mastodon</a>
    {%- endif -%}
   </div>
    <a href="{{ note.url | url }}" class="u-url noteslist-date">
      <time class="dt-published" datetime="{{ note.date | htmlDateString }}">{{ note.date | readableDate }}</time>
    </a>


    {% for tag in note.data.tags %}
      {%- if tag != "notes" -%}
      {% set tagUrl %}/tags/{{ tag }}/{% endset %}
      <a href="{{ tagUrl | url }}" class="tag">{{ tag }}</a>
      {%- endif -%}
    {% endfor %}
  </section>
{% endfor %}
</div>